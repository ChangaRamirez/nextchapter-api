# ---------- MySQL container ----------
MYSQL_DATABASE=goodreads_db
MYSQL_USER=goodreads_user
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# ---------- Spring datasource ----------
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/goodreads_db
SPRING_DATASOURCE_USERNAME=goodreads_user
SPRING_DATASOURCE_PASSWORD=change-me

# ---------- JPA ----------
JPA_DDL_AUTO=update
SHOW_SQL=false

# ---------- JWT ----------
GOODREADS_JWT_SECRET=abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyz
GOODREADS_JWT_EXPIRATION_MS=3600000